# Copy into apps/api/.env for local; set the same keys in Render → Environment

PORT=4000
NODE_ENV=production

# Neon — use Connection string from Neon dashboard (include sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# Long random secret (required for login)
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="8h"

CORS_ORIGIN="https://field-reporting-system.onrender.com"
STORAGE_DRIVER=local
