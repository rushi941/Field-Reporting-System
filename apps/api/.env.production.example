# Set these on Render → Web Service → Environment

PORT=4000
NODE_ENV=production

# Neon on Render — set in Dashboard → Environment (not in this file):
# DATABASE_URL = Direct connection (hostname WITHOUT -pooler) + ?sslmode=require
# Example:
# postgresql://user:pass@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# If you only have the pooler URL (-pooler in host), start-prod strips it for migrate.
# Wake Neon first: open SQL Editor in Neon dashboard before deploy.

JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="https://field-reporting-system.onrender.com"
STORAGE_DRIVER=local
