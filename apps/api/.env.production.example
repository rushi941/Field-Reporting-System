# Copy into apps/api/.env for local; set the same keys in Render → Environment

PORT=4000
NODE_ENV=production

# Render Postgres "Internal Database URL" (or External if needed)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Long random secret (required for login)
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="8h"

# Same origin on Render is fine; set explicitly if UI is on another host
CORS_ORIGIN="https://field-reporting-system.onrender.com"

STORAGE_DRIVER=local
