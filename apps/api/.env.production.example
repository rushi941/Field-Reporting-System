# Set these on Render → Web Service → Environment

PORT=4000
NODE_ENV=production

# Neon — Dashboard → Connection details → copy connection string
# Use Direct (non-pooled) URL. Must include sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="https://field-reporting-system.onrender.com"
STORAGE_DRIVER=local
