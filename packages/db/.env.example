# Local PostgreSQL OR Neon

# Neon — Dashboard → Connection details:
# - DATABASE_URL  = "Pooled" connection string + ?sslmode=require
# - DIRECT_URL    = "Direct" (non-pooled) connection string + ?sslmode=require
# If you only have one URL, set BOTH to the same Direct string.

DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"
