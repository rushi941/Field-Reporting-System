{
  "name": "frs-advance-traffic",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm run dev -w @frs/api\" \"npm run dev -w @frs/web\"",
    "dev:api": "npm run dev -w @frs/api",
    "dev:web": "npm run dev -w @frs/web",
    "build": "npm run db:generate -w @frs/db && npm run build -w @frs/web && node scripts/copy-web-to-api.mjs",
    "start": "node scripts/start-prod.mjs",
    "db:generate": "npm run db:generate -w @frs/db",
    "db:migrate": "npm run db:migrate -w @frs/db",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @frs/db",
    "db:seed": "npm run db:seed -w @frs/db",
    "db:seed:admin": "npm run db:seed:admin -w @frs/db",
    "stop": "node scripts/stop-dev.mjs",
    "smoke": "node scripts/smoke-browser.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "docs:screenshots": "node scripts/capture-flow-screenshots.mjs && node scripts/capture-missing-screenshots.mjs",
    "daily:work": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/daily-work-flow.ps1",
    "daily:schedule": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-daily-task.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2",
    "playwright": "^1.61.1"
  },
  "engines": {
    "node": "20.x"
  }
}
